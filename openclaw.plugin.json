{
  "id": "reflection-plugin",
  "entry": "src/index.ts",
  "configSchema": {
    "type": "object",
    "properties": {
      "workspaceDir": {
        "type": "string",
        "description": "Directory used for USER.md, MEMORY.md, SOUL.md, and IDENTITY.md writes"
      },
      "bufferSize": {
        "type": "integer",
        "minimum": 1,
        "default": 50
      },
      "logLevel": {
        "type": "string",
        "enum": ["debug", "info", "warn", "error"],
        "default": "info"
      },
      "llm": {
        "type": "object",
        "properties": {
          "baseURL": {
            "type": "string",
            "default": "https://api.openai.com/v1"
          },
          "apiKey": {
            "type": "string",
            "default": ""
          },
          "model": {
            "type": "string",
            "default": "gpt-4.1-mini"
          }
        }
      },
      "memoryGate": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "windowSize": {
            "type": "integer",
            "minimum": 1,
            "default": 10
          }
        }
      },
      "consolidation": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "schedule": {
            "type": "string",
            "default": "0 2 * * *"
          }
        }
      }
    }
  }
}
