{
  "id": "reflection-plugin",
  "configSchema": {
    "type": "object",
    "properties": {
      "bufferSize": {
        "type": "integer",
        "minimum": 1,
        "default": 100
      },
      "sessionTTL": {
        "type": "integer",
        "minimum": 1,
        "default": 3600000
      },
      "logLevel": {
        "type": "string",
        "enum": ["debug", "info", "warn", "error"],
        "default": "info"
      }
    }
  }
}
