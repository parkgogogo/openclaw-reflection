{
  "id": "reflection-plugin",
  "entry": "src/index.ts",
  "configSchema": {
    "type": "object",
    "properties": {
      "bufferSize": {
        "type": "integer",
        "minimum": 1,
        "default": 50
      },
      "logLevel": {
        "type": "string",
        "enum": ["debug", "info", "warn", "error"],
        "default": "info"
      },
      "memoryGate": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "windowSize": {
            "type": "integer",
            "minimum": 1,
            "default": 10
          },
          "model": {
            "type": "string",
            "default": "kimi-coding/k2p5"
          }
        }
      },
      "consolidation": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "schedule": {
            "type": "string",
            "default": "0 2 * * *"
          }
        }
      }
    }
  }
}
