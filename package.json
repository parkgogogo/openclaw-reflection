{
  "name": "openclaw-reflection-plugin",
  "version": "1.0.0",
  "description": "OpenClaw plugin for capturing and storing conversation messages in a circular buffer",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "clean": "rm -rf logs",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "reflection",
    "message-buffer"
  ],
  "author": "",
  "license": "MIT",
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "dependencies": {
    "proper-lockfile": "^4.1.2",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@8.6.9+sha512.2cf11a086be557875519e25e1ea8bfa4247f4844e8a2a99272fdb072bd204ea19479ba64b75c3d4c8117d1ac0b3212cedbda7ba5c5dfcf964ee7d07bd139dcd3"
}
